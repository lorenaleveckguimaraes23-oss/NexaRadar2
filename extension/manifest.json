{
  "manifest_version": 3,
  "name": "Nexa Radar",
  "version": "2.0.0",
  "description": "Compare preços e encontre as melhores ofertas.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Nexa Radar"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "http://127.0.0.1:3000/*",
    "http://localhost:3000/*"
  ]
}