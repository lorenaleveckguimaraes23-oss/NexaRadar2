{
  "manifest_version": 3,
  "name": "Nexa Radar",
  "version": "2.1.1",
  "description": "Compare pre\u00e7os e encontre as melhores ofertas.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nexa Radar"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://nexaradar2.onrender.com/*",
    "http://127.0.0.1:3000/*",
    "http://localhost:3000/*"
  ]
}